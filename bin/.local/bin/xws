#!/usr/bin/env bash
# xws - tmux workspace and git worktree manager
# Simple. Direct. No bullshit.

set -euo pipefail

readonly WT_SUFFIX="-worktrees"

err() { echo -e "\033[31mError:\033[0m $*" >&2; }
die() { err "$@"; exit 1; }
info() { echo -e "\033[34m$*\033[0m"; }

_session_enter() {
	local name="$1"
	[[ -n "${TMUX:-}" ]] && tmux switch-client -t "$name" || tmux attach -t "$name"
}

_session_bootstrap() {
	local name="$1"
	local shell_bin="${SHELL:-/bin/zsh}"
	tmux new-session -d -s "$name" -n nvim "$shell_bin" -c "nvim .; exec $shell_bin"
	tmux new-window -t "$name" -n opencode "$shell_bin" -c "opencode; exec $shell_bin"
	tmux new-window -t "$name" -n terminal
}

_session_open_or_create() {
	local name="${1:-$(basename "$PWD")}"

	if tmux has-session -t "$name" 2>/dev/null; then
		_session_enter "$name"
		return 0
	fi

	_session_bootstrap "$name"
	_session_enter "$name"
}

_session_create() {
	[[ "$#" -gt 1 ]] && die "Usage: xws session create [name]"
	local name="${1:-$(basename "$PWD")}"

	if tmux has-session -t "$name" 2>/dev/null; then
		die "Session already exists: $name. Use: xws session open $name"
	fi

	_session_bootstrap "$name"
	_session_enter "$name"
}

_session_open() {
	[[ "$#" -ne 1 ]] && die "Usage: xws session open <name>"
	local name="${1:-}"
	[[ -z "$name" ]] && die "Usage: xws session open <name>"

	tmux has-session -t "$name" 2>/dev/null || die "Session not found: $name"
	_session_enter "$name"
}

_session_kill() {
	[[ "$#" -ne 1 ]] && die "Usage: xws session kill <name>"
	local name="${1:-}"
	[[ -z "$name" ]] && die "Usage: xws session kill <name>"

	tmux has-session -t "$name" 2>/dev/null || die "Session not found: $name"

	local reply
	read -r -p "Kill tmux session '$name'? [y/N] " reply
	if [[ "$reply" =~ ^[Yy]$ ]]; then
		tmux kill-session -t "$name"
		info "Killed session: $name"
	else
		info "Aborted."
	fi
}

_session_list() {
	local sessions
	sessions=$(tmux ls -F '#{session_name}' 2>/dev/null || true)

	if [[ -z "$sessions" ]]; then
		info "No tmux sessions found."
		return 0
	fi

	printf "%s\n" "$sessions"
}

cmd_session() {
	local sub="${1:-}"

	case "$sub" in
	create)
		shift || true
		_session_create "$@"
		;;
	open)
		shift || true
		_session_open "$@"
		;;
	kill)
		shift || true
		_session_kill "$@"
		;;
	list)
		_session_list
		;;
	help|-h|--help|"")
		cat <<'EOF'
Usage: xws session <command>

Commands:
  create [name]  Create a new tmux session
  open <name>    Open an existing tmux session
  kill <name>    Kill a tmux session (asks for confirmation)
  list           List tmux sessions
EOF
		;;
	*)
		die "Unknown session command: '$sub'. Try: create, open, kill, list"
		;;
	esac
}

_find_wt() {
	local folder="$1"
	git worktree list --porcelain 2>/dev/null | while IFS= read -r line; do
		if [[ "$line" == worktree* ]]; then
			local wt="${line#worktree }"
			[[ "$(basename "$wt")" == "$folder" ]] && echo "$wt" && break
		fi
	done
}

_main_worktree_path() {
	git worktree list --porcelain 2>/dev/null | while IFS= read -r line; do
		if [[ "$line" == worktree* ]]; then
			printf '%s\n' "${line#worktree }"
			break
		fi
	done
}

_resolve() {
	local input="$1"

	git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Not a git repository."

	local main
	main=$(_main_worktree_path)
	[[ -z "$main" ]] && die "Could not find main repository."

	local dir
	local name
	dir=$(dirname "$main")
	name=$(basename "$main")

	REPO_ROOT="$main"
	WT_ROOT="${dir}/${name}${WT_SUFFIX}"

	BRANCH="$input"
	FOLDER="${input//\//_}"

	local existing
	existing=$(_find_wt "$FOLDER")
	if [[ -n "$existing" ]]; then
		WT_PATH="$existing"
	else
		WT_PATH="${WT_ROOT}/${FOLDER}"
	fi
}

_detect_install_manager() {
	local path="$1"
	local pkg="${path}/package.json"
	[[ ! -f "$pkg" ]] && return 0

	local pm_field
	pm_field=$(grep -o '"packageManager": *"[^"]*"' "$pkg" 2>/dev/null | cut -d '"' -f 4 || true)
	case "$pm_field" in
	bun*) echo "bun"; return 0 ;;
	yarn*) echo "yarn"; return 0 ;;
	pnpm*) echo "pnpm"; return 0 ;;
	npm*) echo "npm"; return 0 ;;
	esac

	[[ -f "${path}/bun.lock" || -f "${path}/bun.lockb" ]] && echo "bun" && return 0
	[[ -f "${path}/pnpm-lock.yaml" ]] && echo "pnpm" && return 0
	[[ -f "${path}/yarn.lock" ]] && echo "yarn" && return 0
	[[ -f "${path}/package-lock.json" ]] && echo "npm" && return 0
	echo "bun"
}

_run_install() {
	local manager="$1"

	case "$manager" in
	"")
		return 0
		;;
	bun)
		info "Installing dependencies with bun"
		bun install
		;;
	pnpm)
		info "Installing dependencies with pnpm"
		pnpm install
		;;
	yarn)
		info "Installing dependencies with yarn"
		yarn install
		;;
	npm)
		info "Installing dependencies with npm"
		npm install
		;;
	*)
		die "Unknown package manager: $manager"
		;;
	esac
}

_parse() {
	INPUT=""
	SESSION=""

	while [[ "$#" -gt 0 ]]; do
		case "$1" in
		--name)
			[[ "$#" -lt 2 ]] && die "Missing value for --name"
			[[ -z "${2:-}" || "${2:0:1}" == "-" ]] && die "Invalid value for --name"
			[[ -n "$SESSION" ]] && die "--name can only be set once"
			SESSION="$2"
			shift 2
			;;
		--*)
			die "Unknown option: $1"
			;;
		*)
			[[ -n "$INPUT" ]] && die "Too many arguments. Expected one branch name."
			INPUT="$1"
			shift
			;;
		esac
	done

	[[ -z "$INPUT" ]] && return 1
	[[ -z "$SESSION" ]] && SESSION="$INPUT"
	return 0
}

wt_create() {
	local INPUT SESSION
	_parse "$@" || die "Usage: xws worktree create <branch> [--name <session>]"

	local BRANCH FOLDER WT_PATH WT_ROOT REPO_ROOT
	_resolve "$INPUT"

	[[ -d "$WT_PATH" ]] && die "Worktree exists: $WT_PATH"

	mkdir -p "$WT_ROOT"

	if ! git show-ref --verify --quiet "refs/heads/${BRANCH}" 2>/dev/null; then
		info "Creating branch: $BRANCH"
		git branch "$BRANCH"
	fi

	info "Creating worktree: $WT_PATH"
	git worktree add "$WT_PATH" "$BRANCH"

	mkdir -p "${WT_PATH}/.xws"
	printf '%s\n' "$SESSION" > "${WT_PATH}/.xws/session"

	[[ -f "${REPO_ROOT}/.env" ]] && cp "${REPO_ROOT}/.env" "${WT_PATH}/.env"
	[[ -d "${REPO_ROOT}/.opencode" ]] && cp -r "${REPO_ROOT}/.opencode" "${WT_PATH}/"

	cd "$WT_PATH" || die "Cannot enter $WT_PATH"

	local manager
	manager=$(_detect_install_manager "$WT_PATH")
	_run_install "$manager"

	_session_open_or_create "$SESSION"
}

wt_open() {
	local INPUT SESSION
	_parse "$@" || die "Usage: xws worktree open <branch> [--name <session>]"

	if [[ "$INPUT" == "main" || "$INPUT" == "master" ]]; then
		local main
		main=$(_main_worktree_path)
		[[ -z "$main" ]] && die "Cannot determine main worktree path"
		cd "$main" || die "Cannot access main repo"
		_session_open_or_create "$SESSION"
		return 0
	fi

	local BRANCH FOLDER WT_PATH
	_resolve "$INPUT"

	[[ ! -d "$WT_PATH" ]] && die "Worktree not found: $WT_PATH"

	if [[ -f "${WT_PATH}/.xws/session" ]]; then
		local saved
		saved=$(cat "${WT_PATH}/.xws/session")
		[[ "$SESSION" == "$INPUT" ]] && SESSION="$saved"
	fi

	cd "$WT_PATH" || die "Cannot enter $WT_PATH"
	_session_open_or_create "$SESSION"
}

wt_remove() {
	local input=""
	local force=false

	while [[ "$#" -gt 0 ]]; do
		case "$1" in
		-f|--force)
			force=true
			;;
		--*)
			die "Unknown option: $1"
			;;
		*)
			[[ -n "$input" ]] && die "Too many arguments. Expected one branch name."
			input="$1"
			;;
		esac
		shift
	done

	[[ -z "$input" ]] && die "Usage: xws worktree remove <branch> [-f|--force]"
	[[ "$input" == "main" || "$input" == "master" ]] && die "Cannot remove main worktree"

	local BRANCH FOLDER WT_PATH
	_resolve "$input"

	[[ ! -d "$WT_PATH" ]] && die "Worktree not found: $WT_PATH"

	if [[ -n "$(cd "$WT_PATH" && git status --porcelain 2>/dev/null)" ]]; then
		[[ "$force" == false ]] && die "Uncommitted changes. Use -f to force."
	fi

	local session="$input"
	[[ -f "${WT_PATH}/.xws/session" ]] && session=$(cat "${WT_PATH}/.xws/session")

	if tmux has-session -t "$session" 2>/dev/null; then
		local reply
		read -r -p "Kill tmux session '$session'? [y/N] " reply
		[[ "$reply" =~ ^[Yy]$ ]] && tmux kill-session -t "$session"
	fi

	info "Removing worktree: $WT_PATH"
	git worktree remove "$WT_PATH"

	rmdir "$(dirname "$WT_PATH")" 2>/dev/null || true

	info "Removed: $FOLDER"
}

wt_list() {
	git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Not a git repository."

	local main
	main=$(_main_worktree_path)

	git worktree list --porcelain 2>/dev/null | while IFS= read -r line; do
		[[ "$line" != worktree* ]] && continue

		local wt="${line#worktree }"
		local folder
		folder=$(basename "$wt")

		read -r _head || true
		read -r branch_line || true

		local branch=""
		[[ "$branch_line" == branch* ]] && branch="${branch_line#branch refs/heads/}"

		local mark=""
		[[ "$wt" == "$main" ]] && mark=" (main)"

		printf "  %-25s %s%s\n" "$folder" "$branch" "$mark"
	done
}

cmd_worktree() {
	local cmd="${1:-}"
	shift || true

	case "$cmd" in
	create) wt_create "$@" ;;
	open) wt_open "$@" ;;
	remove) wt_remove "$@" ;;
	list) wt_list ;;
	help|-h|--help)
		echo "Usage: xws worktree <command>"
		echo "Commands: create <branch> [--name <session>], open <branch> [--name <session>], remove <branch>, list"
		;;
	*) die "Unknown: '$cmd'. Try: create, open, remove, list" ;;
	esac
}

cmd_help() {
cat <<'EOF'
xws - tmux workspace and git worktree manager

Usage: xws <command> [options]

Commands:
  session <command>          Manage tmux sessions
  worktree create <branch>  Create worktree for branch
  worktree open <branch>    Open worktree in session
  worktree remove <branch>  Remove worktree
  worktree list             List all worktrees

Session Commands:
  create [name]  Create new tmux session
  open <name>    Open existing tmux session
  kill <name>    Kill tmux session
  list           List tmux sessions

Examples:
  xws session create           # Create session named after current dir
  xws session create api       # Create new session
  xws session open api         # Open existing session
  xws session kill api         # Kill session (asks for confirmation)
  xws worktree create feat/x   # Create worktree for feat/x branch
  xws worktree open feat/x     # Open existing worktree
  xws worktree remove feat/x   # Remove worktree (prompts for tmux)
EOF
}

main() {
	local cmd="${1:-}"
	shift || true

	case "$cmd" in
	session) cmd_session "$@" ;;
	worktree) cmd_worktree "$@" ;;
	help|-h|--help) cmd_help ;;
	"") cmd_help ;;
	*) die "Unknown: '$cmd'. Try: session, worktree, help" ;;
	esac
}

main "$@"
